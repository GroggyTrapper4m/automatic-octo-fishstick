{
  "globalHeaders": {
    "Access-Control-Allow-Origin": "*",
    "Cache-Control": "public, max-age=3600"
  },
  "routes": [
    {
      "route": "/v1/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable" 
      }
    },
    {
      "route": "/v2/*",
      "headers": {
        "Cache-Control": "no-cache" 
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "mimeTypes": {
    ".js": "text/javascript"
  }
}